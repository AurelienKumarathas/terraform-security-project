\n  root_block_device {\n    volume_size = 50\n    encrypted   = false  # Should be true\n  }\n\n  tags = {\n    Name = \"App Server\"\n  }\n}\n"}}}}]}, {"ruleId": "CKV_AWS_126", "ruleIndex": 8, "level": "error", "attachments": [], "message": {"text": "Ensure that detailed monitoring is enabled for EC2 instances"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "terraform/main.tf"}, "region": {"startLine": 67, "endLine": 85, "snippet": {"text": "resource \"aws_instance\" \"app_server\" {\n  ami           = var.ami_id\n  instance_type = \"t3.medium\"\n\n  vpc_security_group_ids = [aws_security_group.app_sg.id]\n  subnet_id              = aws_subnet.private.id\n\n  # Missing: IMDSv2 requirement\n  # Missing: EBS encryption\n\n  root_block_device {\n    volume_size = 50\n    encrypted   = false  # Should be true\n  }\n\n  tags = {\n    Name = \"App Server\"\n  }\n}\n"}}}}]}, {"ruleId": "CKV_AWS_135", "ruleIndex": 9, "level": "error", "attachments": [], "message": {"text": "Ensure that EC2 is EBS optimized"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "terraform/main.tf"}, "region": {"startLine": 67, "endLine": 85, "snippet": {"text": "resource \"aws_instance\" \"app_server\" {\n  ami           = var.ami_id\n  instance_type = \"t3.medium\"\n\n  vpc_security_group_ids = [aws_security_group.app_sg.id]\n  subnet_id              = aws_subnet.private.id\n\n  # Missing: IMDSv2 requirement\n  # Missing: EBS encryption\n\n  root_block_device {\n    volume_size = 50\n    encrypted   = false  # Should be true\n  }\n\n  tags = {\n    Name = \"App Server\"\n  }\n}\n"}}}}]}, {"ruleId": "CKV_AWS_8", "ruleIndex": 10, "level": "error", "attachments": [], "message": {"text": "Ensure all data stored in the Launch configuration or instance Elastic Blocks Store is securely encrypted"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "terraform/main.tf"}, "region": {"startLine": 67, "endLine": 85, "snippet": {"text": "resource \"aws_instance\" \"app_server\" {\n  ami           = var.ami_id\n  instance_type = \"t3.medium\"\n\n  vpc_security_group_ids = [aws_security_group.app_sg.id]\n  subnet_id              = aws_subnet.private.id\n\n  # Missing: IMDSv2 requirement\n  # Missing: EBS encryption\n\n  root_block_device {\n    volume_size = 50\n    encrypted   = false  # Should be true\n  }\n\n  tags = {\n    Name = \"App Server\"\n  }\n}\n"}}}}]}, {"ruleId": "CKV_AWS_161", "ruleIndex": 11, "level": "error", "attachments": [], "message": {"text": "Ensure RDS database has IAM authentication enabled"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "terraform/main.tf"}, "region": {"startLine": 109, "endLine": 132, "snippet": {"text": "resource \"aws_db_instance\" \"main\" {\n  identifier        = \"quantumtrade-db\"\n  engine            = \"postgres\"\n  engine_version    = \"14\"\n  instance_class    = \"db.t3.medium\"\n  allocated_storage = 100\n\n  db_name  = \"quantumtrade\"\n  username = \"admin\"\n  password = var.db_password\n\n  vpc_security_group_ids = [aws_security_group.app_sg.id]\n  db_subnet_group_name   = aws_db_subnet_group.main.name\n\n  storage_encrypted = false  # Should be true\n\n  # Missing: deletion protection\n  # Missing: backup retention\n  # Missing: multi-AZ\n\n  tags = {\n    Name = \"QuantumTrade Database\"\n  }\n}\n"}}}}]}, {"ruleId": "CKV_AWS_293", "ruleIndex": 12, "level": "error", "attachments": [], "message": {"text": "Ensure that AWS database instances have deletion protection enabled"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "terraform/main.tf"}, "region": {"startLine": 109, "endLine": 132, "snippet": {"text": "resource \"aws_db_instance\" \"main\" {\n  identifier        = \"quantumtrade-db\"\n  engine            = \"postgres\"\n  engine_version    = \"14\"\n  instance_class    = \"db.t3.medium\"\n  allocated_storage = 100\n\n  db_name  = \"quantumtrade\"\n  username = \"admin\"\n  password = var.db_password\n\n  vpc_security_g